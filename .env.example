# ===========================================================================
# Variables de entorno para el sitio Griffo (griffo.com.ar)
# Copiá este archivo como .env.local y completá los valores.
# En producción se configuran en Vercel → Settings → Environment Variables.
# ===========================================================================

# Dominio canónico. Default: staging. En Production (Vercel) apunta a
# https://www.griffo.com.ar.
NEXT_PUBLIC_SITE_URL=https://web-omega-wheat-25.vercel.app

# ---------- API de catálogo (SpecParts) ----------
# Credenciales OAuth client_credentials. Las provee SpecParts.
# Son las mismas que usa app.griffo.com.ar — ver reference/arquitectura-app-griffo.md.
SPECPARTS_CLIENT_ID=
SPECPARTS_CLIENT_SECRET=

# ---------- Email (Resend) ----------
# Contacto, garantía y newsletter. Sender configurado en src/lib/resend.ts.
RESEND_API_KEY=

# ---------- Admin panel (/admin) ----------
ADMIN_PASSWORD=

# ---------- Vercel KV (Upstash Redis) ----------
# Distribuidores dinámicos, links de productos, banners. Se autollena al
# vincular el Storage en Vercel.
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=

# ---------- Bejerman (ERP) ----------
# Middleware de Bejerman para el portal B2B (/cuenta/*).
# Ver reference/bejerman/README.md para docs y endpoints.
# Las credenciales las provee el proveedor del middleware — pedirlas
# con el template en reference/bejerman/mail-al-proveedor.md.
BEJERMAN_API_URL=
BEJERMAN_API_KEY=
# Solo si la auth es OAuth client_credentials:
BEJERMAN_API_SECRET=

# ---------- Firebase (Auth B2B) ----------
# Para el portal /cuenta/* reusamos el proyecto "griffo-app" de la app mobile.
# Config pública (client-side) del SDK:
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
# Service account JSON (server-side, para validar tokens de Firebase en el
# middleware). Pegar el JSON completo en una sola línea, escapado.
FIREBASE_ADMIN_CREDENTIALS=
