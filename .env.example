# ===========================================================================
# Variables de entorno para el sitio Griffo (griffo.com.ar)
# Copiá este archivo como .env.local y completá los valores.
# En producción se configuran en Vercel → Settings → Environment Variables.
# ===========================================================================

# Dominio canónico. Default: staging. En Production (Vercel) apunta a
# https://www.griffo.com.ar.
NEXT_PUBLIC_SITE_URL=https://web-omega-wheat-25.vercel.app

# ---------- API de catálogo (SpecParts) ----------
# Credenciales OAuth client_credentials. Las provee SpecParts.
# Son las mismas que usa app.griffo.com.ar — ver reference/arquitectura-app-griffo.md.
SPECPARTS_CLIENT_ID=
SPECPARTS_CLIENT_SECRET=

# ---------- Email (Resend) ----------
# Contacto, garantía y newsletter. Sender configurado en src/lib/resend.ts.
RESEND_API_KEY=

# ---------- Admin panel (/admin) ----------
ADMIN_PASSWORD=

# ---------- Vercel KV (Upstash Redis) ----------
# Distribuidores dinámicos, links de productos, banners. Se autollena al
# vincular el Storage en Vercel.
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=
